# Telegram bot token and user whitelist are configured in WebUI → Adapters → adapter-telegram
# (persisted in the adapter volume; optional override: ADAPTER_CONFIG_PATH in the service env).

# LLM upstream URL, API keys, and model ids are not configured in this root .env;
# use WebUI → LLM → {component} or PUT via orchestrator `/api/v1/llm-components/{name}/config`.
# Optional override when running llm-openai outside compose (default in image: /data/llm-config.json):
# LLM_CONFIG_PATH=/data/llm-config.json

# Service ports
ORCHESTRATOR_PORT=8080
SESSION_PORT=8090
LLM_OPENAI_PORT=8081
USER_DOCKER_MANAGER_PORT=8082
ADAPTER_TELEGRAM_PORT=8084
RUNTIME_PORT=8085
SKILLS_PORT=8093
LOGGER_PORT=8086
STATS_PORT=8092
# Reserved when memory is re-added to compose (see memory/TODO.md)
MEMORY_PORT=8087
WORKSPACE_PORT=8088
WEBUI_PORT=3000

# ReAct loop cap (runtime → llm-openai tool rounds)
REACT_MAX_STEPS=16
# When a healthy skills service is registered: inject top FTS hits into the model context (1=on, 0=off)
RUNTIME_SKILLS_INJECT=1
RUNTIME_SKILLS_TOP_K=5
# Runtime plan gate: classifier (default) = JSON gate + mutating tool intercept; legacy_keyword = old keyword-only plan-first
# RUNTIME_PLAN_GATE=classifier

# Orchestrator upstream timeout when proxying long runtime/tool calls (seconds)
ORCHESTRATOR_UPSTREAM_TIMEOUT_SEC=240

# Telegram adapter timeout for /api/v1/chat round trip (seconds)
ADAPTER_TELEGRAM_CHAT_TIMEOUT_SEC=240

# Health-check tuning
HEALTHCHECK_INTERVAL_SEC=5
HEALTHCHECK_FAIL_THRESHOLD=3

# Session cap (messages kept per session_id)
SESSION_MAX_MESSAGES=40

# Session idle timeout: if no new messages for this many seconds, the session is marked expired
SESSION_IDLE_SEC=86400

# userdocker: temporary (session_scoped) container removal if untouched for this long (seconds).
# If unset, defaults to USERDOCKER_IDLE_HOURS * 3600.
USERDOCKER_TEMP_TTL_SEC=

# userdocker idle sweeper tick (still used)
USERDOCKER_IDLE_HOURS=24
USERDOCKER_IDLE_CHECK_SEC=300

# framework-managed image allowlist (comma-separated)
USERDOCKER_ALLOWED_IMAGES=whalesbot/userdocker-base:latest,whalesbot/userdocker-golang:latest
