# Telegram bot token (leave empty to disable the Telegram poller; the service still runs and self-registers)
TELEGRAM_BOT_TOKEN=

# OpenAI-compatible Chat Completions endpoint.
#
# MODEL_BASE_URL examples:
#   https://api.openai.com             OpenAI cloud
#   http://localhost:11434             Ollama on the host (auto-rewritten to host.docker.internal)
#   http://127.0.0.1:1234              LM Studio on the host (auto-rewritten)
#   http://host.docker.internal:8000   any service on the host
#   http://my-sidecar:8000             another container on mvp_net
MODEL_PROVIDER=openai_compatible
MODEL_BASE_URL=https://api.openai.com
MODEL_API_KEY=
MODEL_NAME=gpt-4o-mini

# Service ports
ORCHESTRATOR_PORT=8080
SESSION_PORT=8090
CHATMODEL_PORT=8081
USER_DOCKER_MANAGER_PORT=8082
IM_TELEGRAM_PORT=8084
RUNTIME_PORT=8085
LOGGER_PORT=8086
MEMORY_PORT=8087
WORKSPACE_PORT=8088
WEBUI_PORT=3000

# ReAct loop cap (runtime → chatmodel tool rounds)
REACT_MAX_STEPS=16

# Orchestrator upstream timeout when proxying long runtime/tool calls (seconds)
ORCHESTRATOR_UPSTREAM_TIMEOUT_SEC=240

# Telegram gateway timeout for /api/v1/chat round trip (seconds)
IM_TELEGRAM_CHAT_TIMEOUT_SEC=240

# Health-check tuning
HEALTHCHECK_INTERVAL_SEC=5
HEALTHCHECK_FAIL_THRESHOLD=3

# Session cap (messages kept per session_id)
SESSION_MAX_MESSAGES=40

# userdocker session-scoped idle cleanup
USERDOCKER_IDLE_HOURS=24
USERDOCKER_IDLE_CHECK_SEC=300

# framework-managed image allowlist (comma-separated)
USERDOCKER_ALLOWED_IMAGES=whalesbot/userdocker-base:latest,whalesbot/userdocker-golang:latest
